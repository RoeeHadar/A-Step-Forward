{
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @asf/web build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_APP_NAME": "A Step Forward"
  },
  "crons": [
    {
      "path": "/api/cron/consolidate-memory?limit=25",
      "schedule": "0 3 * * 0"
    }
  ]
}
