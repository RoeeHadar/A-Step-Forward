# Copy to apps/web/.env.local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=https://a-step-forward-waij.vercel.app
NEXT_PUBLIC_APP_NAME=A Step Forward
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── LLM (OpenAI-compatible: Groq, Ollama, vLLM, Together, OpenRouter) ──
# Unified vars (preferred):
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_PRIMARY_MODEL=llama-3.3-70b-versatile
LLM_CHEAP_MODEL=llama-3.1-8b-instant
LLM_FALLBACK_MODELS=gemma2-9b-it
# Legacy Groq aliases (still supported):
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Local Ollama example:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_PRIMARY_MODEL=qwen2.5:32b-instruct

# E2E tests (optional)
E2E_CLERK_EMAIL=
E2E_CLERK_PASSWORD=
