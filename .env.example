# ===== Core =====
APP_ENV=local
APP_NAME=a-step-forward
LOG_LEVEL=INFO
SECRET_KEY=change-me-32-bytes-min-xxxxxxxxxxxxxxxxxxxxxx
ENCRYPTION_KEY=change-me-32-bytes-base64-xxxxxxxxxxxxxxxxx

# ===== Postgres + pgvector =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=astepforward
POSTGRES_USER=astepforward
POSTGRES_PASSWORD=astepforward
DATABASE_URL=postgresql+asyncpg://astepforward:astepforward@localhost:5432/astepforward

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Neo4j (knowledge graph) =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=astepforward
NEO4J_DATABASE=neo4j

# ===== Object storage =====
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=astepforward-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio
S3_REGION=us-east-1

# ===== Auth (Clerk) =====
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# JWKS URL from Clerk Dashboard → API Keys → Advanced → JWKS Endpoint
CLERK_JWKS_URL=
# Optional: validate issuer/audience in production (recommended)
CLERK_ISSUER=
CLERK_AUDIENCE=

# ===== LLM providers =====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# Model routing defaults
LLM_DEFAULT_MODEL=claude-sonnet-4-5
LLM_DEEP_MODEL=claude-opus-4-8
LLM_CHEAP_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=voyage-3-large
RERANK_MODEL=rerank-2

# ===== Tracing & evals =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
RATE_LIMIT_ENABLED=true
# Allow X-Role header overrides in local dev only (never enable in production)
DEV_ALLOW_ROLE_HEADERS=false

# ===== Tools / MCP =====
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
WOLFRAM_APP_ID=

# ===== Frontend (apps/web) =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=A Step Forward
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ===== Memory tuning =====
MEMORY_DECAY_TAU_DAYS=14
MEMORY_CONSOLIDATION_DUP_COSINE=0.92
MEMORY_KG_PROMOTE_SALIENCE=0.7
MEMORY_CONTEXT_COMPACT_RATIO=0.8
MEMORY_DREAM_CRON=0 3 * * *

# ===== GraphRAG =====
USE_NEO4J=false
USE_POSTGRES_CHUNKS=false
GRAPHRAG_VERIFICATION_SAMPLE_RATE=0.1

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
