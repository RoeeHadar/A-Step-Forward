# ===== Core =====
APP_ENV=local
APP_NAME=a-step-forward
LOG_LEVEL=INFO
SECRET_KEY=change-me-32-bytes-min-xxxxxxxxxxxxxxxxxxxxxx
ENCRYPTION_KEY=change-me-32-bytes-base64-xxxxxxxxxxxxxxxxx

# ===== Postgres + pgvector =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=astepforward
POSTGRES_USER=astepforward
POSTGRES_PASSWORD=astepforward
DATABASE_URL=postgresql+asyncpg://astepforward:astepforward@localhost:5432/astepforward

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Neo4j (knowledge graph) =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=astepforward
NEO4J_DATABASE=neo4j

# ===== Object storage =====
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=astepforward-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio
S3_REGION=us-east-1

# ===== Auth (Clerk) =====
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# JWKS URL from Clerk Dashboard → API Keys → Advanced → JWKS Endpoint
CLERK_JWKS_URL=
# Optional: validate issuer/audience in production (recommended)
CLERK_ISSUER=
CLERK_AUDIENCE=

# ===== LLM providers (OpenAI-compatible) =====
# Unified — used by apps/web and packages/agents when set:
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_PRIMARY_MODEL=llama-3.3-70b-versatile
LLM_CHEAP_MODEL=llama-3.1-8b-instant
LLM_FALLBACK_MODELS=gemma2-9b-it
# Legacy Groq aliases (backward compatible):
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

# Model routing defaults (Python agents manifest — optional overrides)
LLM_DEFAULT_MODEL=llama-3.3-70b-versatile
LLM_DEEP_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=voyage-3-large
RERANK_MODEL=rerank-2

# ===== Tracing & evals =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
RATE_LIMIT_ENABLED=true
# Allow X-Role header overrides in local dev only (never enable in production)
DEV_ALLOW_ROLE_HEADERS=false

# ===== Tools / MCP =====
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
WOLFRAM_APP_ID=

# ===== Email (bookings) =====
RESEND_API_KEY=
RESEND_FROM=A Step Forward <onboarding@resend.dev>
TUTOR_EMAIL=
BOOKING_API_SECRET=

# Set the same BOOKING_API_SECRET on Vercel (web) and Render (api)

# ===== Content storage (Bagrut PDFs) =====
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# ===== Frontend (apps/web) =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=A Step Forward
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ===== Memory tuning =====
MEMORY_DECAY_TAU_DAYS=14
MEMORY_CONSOLIDATION_DUP_COSINE=0.92
MEMORY_KG_PROMOTE_SALIENCE=0.7
MEMORY_CONTEXT_COMPACT_RATIO=0.8
MEMORY_DREAM_CRON=0 3 * * *

# ===== GraphRAG =====
USE_NEO4J=false
USE_POSTGRES_CHUNKS=false
GRAPHRAG_VERIFICATION_SAMPLE_RATE=0.1

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
