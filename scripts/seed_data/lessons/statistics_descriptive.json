        },
        "4pt": {
          "body_en_md": "Add $\\sigma$ in same units as data.",
          "body_he_md": "ОћОЋОАОЎОцОЋ $\\sigma$ ОЉОљОЋОфОЪ ОЎОЌОЎОЊОЋОф."
        },
        "5pt": {
          "body_en_md": "Add variance and z-scores.",
          "body_he_md": "ОћОЋОАОЎОцОЋ ОЕОЋОаОЋОф ОЋОдОЎОЋОаОЎ z."
        }
