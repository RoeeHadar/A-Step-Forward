    {
      "kind": "theory",
      "title_en": "Mean, median, mode",
      "title_he": "ОъОъОЋОдОб, ОЌОдОЎОЋОЪ, ОЕОЏОЎОЌ",
      "body_en_md": "Mean $\\bar{x}=\\sum x/n$ (sensitive to outliers). Median = middle after **sorting**. Mode = most frequent. Range = maxРѕњmin. $\\sigma=\\sqrt{\\frac1n\\sum(x_i-\\bar{x})^2}$. $z = \\dfrac{x - \\bar{x}}{\\sigma}$.",
      "body_he_md": "ОъОъОЋОдОб $\\bar{x}=\\sum x/n$ (ОеОњОЎОЕ ОюОЌОеОЎОњОЎОЮ). ОЌОдОЎОЋОЪ = ОљОъОдОб ОљОЌОе **ОъОЎОЋОЪ**. ОЕОЏОЎОЌ = ОћОЏОЎ ОфОЏОЋОБ. ОўОЋОЋОЌ = maxРѕњmin. $\\sigma=\\sqrt{\\frac1n\\sum(x_i-\\bar{x})^2}$. $z = \\dfrac{x - \\bar{x}}{\\sigma}$.",
      "body_by_level": {
        "3pt": {
          "body_en_md": "Four formulas + read charts.",
          "body_he_md": "ОљОеОЉОб ОаОЋОАОЌОљОЋОф + ОДОеОЎОљОф ОњОеОцОЎОЮ."
        },
        "4pt": {
          "body_en_md": "Shortcut $\\sigma^2=\\overline{x^2}-\\bar{x}^2$.",
          "body_he_md": "ОДОЎОдОЋОе $\\sigma^2=\\overline{x^2}-\\bar{x}^2$."
        },
        "5pt": {
          "body_en_md": "Interpret |z|.",
          "body_he_md": "ОцОеОЕОаОЋОф |z|."
        }
      }
    },
    {
      "kind": "worked_example",
      "title_en": "Test scores worked example",
      "title_he": "ОЊОЋОњОъОћ: ОдОЎОЋОаОЎ ОъОЉОЌОЪ",
