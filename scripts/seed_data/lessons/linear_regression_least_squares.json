  "sections": [
    {
      "id": "problem_setup",
      "title_en": "Problem Setup and Least Squares Criterion",
      "title_he": "Setup",
      "level_min": "university",
      "body_en_md": "Given $(x_i,y_i)$ find $\\hat y=a+bx$. Minimize $SS_{res}=\\sum(y_i-\\hat y_i)^2$.",
      "body_he_md": "Minimize residuals."
    },
    {
      "id": "ols_formulas",
      "title_en": "OLS Formulas and Correlation",
      "title_he": "OLS",
      "level_min": "university",
      "body_en_md": "$b=S_{xy}/S_{xx}$, $a=\\bar y-b\\bar x$, $r=S_{xy}/\\sqrt{S_{xx}S_{yy}}$, $R^2=r^2$.",
      "body_he_md": "Formulas."
    },
    {
      "id": "worked_example",
      "title_en": "Worked Example — Height vs Weight",
      "title_he": "Example",
      "level_min": "university",
      "body_en_md": "(160,55),(170,65),(180,75): $b=1$, $a=-105$, $\\hat y=-105+x$.",
      "body_he_md": "Example."
    },
    {
      "id": "prediction_residuals",
      "title_en": "Prediction, Extrapolation, and Residuals",
      "title_he": "Prediction",
      "level_min": "university",
      "body_en_md": "$e_i=y_i-\\hat y_i$. Extrapolation is risky.",
      "body_he_md": "Residuals."
    }
  ],
