  "sections": [
    {
      "id": "what_is_lp",
      "title_en": "What is Linear Programming?",
      "title_he": "מהו תכנון לינארי?",
      "body_en_md": "**Linear programming** optimizes $Z=ax+by$ subject to linear constraints. The **feasible region** is the intersection of half-planes.\n\n**Factory example:** chairs $x$, tables $y$; $2x+4y\\le120$; $3x+2y\\le90$; maximize $Z=40x+60y$.",
      "body_he_md": "LP — מקס/מין של $Z=ax+by$ תחת אילוצים. דוגמה: $2x+4y\\le120$, $3x+2y\\le90$, מקס $Z=40x+60y$.",
      "level_min": "3pt"
    },
    {
      "id": "constraints",
      "title_en": "Setting Up Constraints",
      "title_he": "הגדרת אילוצים",
      "body_en_md": "Define variables, write inequalities, graph lines, find **corner points**.\n\nExample: $x+2y\\le10$, $2x+y\\le12$. Corners: $(0,0)$, $(0,5)$, $(14/3,8/3)$, $(6,0)$.",
      "body_he_md": "משתנים, אילוצים, גרף, **קודקודים**.",
      "level_min": "3pt"
    },
    {
      "id": "optimal",
      "title_en": "Finding the Optimal Solution",
      "title_he": "מציאת הפתרון",
      "body_en_md": "**Corner-point theorem:** optimum of bounded LP is at a vertex. Evaluate $Z$ at each corner.\n\nMax $Z=3x+2y$ gives $58/3$ at $(14/3,8/3)$.",
      "body_he_md": "משפט נקודות קיצון: optimum בקודקוד.",
      "level_min": "3pt"
    },
    {
      "id": "exam",
      "title_en": "Exam-Style Problems",
      "title_he": "תרגול בסגנון בחינה",
      "body_en_md": "**Problem 1:** 100 acres, 8000 NIS. A: 3 NIS/acre, 20 kg; B: 5 NIS/acre, 35 kg; max 60 each. **Answer:** $(50,50)$, 2750 kg yield.\n\n**Problem 2:** Parametric $Z=kx+(10-k)y$ under standard constraints.",
      "body_he_md": "בעיה 1: (50,50), 2750 ק\"ג.",
      "level_min": "3pt"
    },
    {
      "id": "strategy",
      "title_en": "Strategy for Bagrut (372)",
      "title_he": "אסטרטגיה לבגרות",
      "body_en_md": "Steps: variables, constraints, graph, corners, evaluate $Z$. Traps: open region, wrong inequality, missing $x,y\\ge0$.",
      "body_he_md": "משתנים → אילוצים → גרף → קודקודים → $Z$.",
      "level_min": "3pt"
    }
