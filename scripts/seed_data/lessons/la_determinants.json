  "title_en": "Determinants",
  "title_he": "דטרמיננטות",
  "summary_en": "The determinant encodes invertibility, area/volume scaling, and enables Cramer's rule.",
  "summary_he": "הדטרמיננטה מקודדת הפיכות וקנה מידה של שטח/נפח.",
  "est_minutes": 30,
  "sections": [
    {
      "kind": "intro",
      "title_en": "What is a Determinant? (2x2)",
      "title_he": "מהי דטרמיננטה? (2x2)",
      "body_en_md": "For $2\\times2$: $\\det(A)=ad-bc$. Zero det iff singular. $|det(A)|$ = parallelogram area.",
      "body_he_md": "עבור $2\\times2$: $\\det(A)=ad-bc$. דטרמיננטה אפסית אם ורק אם סינגולרית.",
      "body_by_level": {
        "la": {
          "body_en_md": "$\\det(A)=ad-bc$. Zero iff singular.",
          "body_he_md": "$\\det(A)=ad-bc$. אפס אם ורק אם סינגולרית."
        }
      }
    },
    {
      "kind": "theory",
      "title_en": "3x3 Cofactor Expansion",
      "title_he": "דטרמיננטה 3x3",
      "body_en_md": "Expand along row/column with most zeros. Example: $\\det\\begin{pmatrix}1&2&0\\\\3&-1&4\\\\0&2&1\\end{pmatrix}=-15$.",
      "body_he_md": "פתח לאורך שורה/עמודה עם הכי הרבה אפסים. דוגמה: $\\det=-15$.",
      "body_by_level": {
        "la": {
          "body_en_md": "Sign at $(i,j)$ is $(-1)^{i+j}$.",
          "body_he_md": "הסימן ב-$(i,j)$ הוא $(-1)^{i+j}$."
        }
      }
    },
    {
      "kind": "theory",
      "title_en": "Properties",
      "title_he": "תכונות",
      "body_en_md": "$\\det(AB)=\\det(A)\\det(B)$; row swap flips sign; triangular det = product of diagonal.",
      "body_he_md": "$\\det(AB)=\\det(A)\\det(B)$; החלפת שורות הופכת סימן.",
      "body_by_level": {
        "la": {
          "body_en_md": "Product rule + row operations.",
          "body_he_md": "כלל מכפלה + פעולות שורות."
        }
      }
    },
    {
      "kind": "worked_example",
      "title_en": "Cramer's Rule",
      "title_he": "כלל קרמר",
      "body_en_md": "$x_j=\\det(A_j)/\\det(A)$. Example: $3x+y=7$, $x-y=1$ gives $x=2$, $y=1$.",
      "body_he_md": "$x_j=\\det(A_j)/\\det(A)$. דוגמה: $x=2$, $y=1$.",
      "body_by_level": {
        "la": {
          "body_en_md": "Efficient for 2x2/3x3.",
          "body_he_md": "יעיל ל-2x2/3x3."
        }
      }
    },
    {
      "kind": "summary",
      "title_en": "Summary",
      "title_he": "סיכום",
      "body_en_md": "det=0 iff singular; |det| = scaling factor; Cramer for small systems.",
      "body_he_md": "det=0 אם ורק אם סינגולרית; |det| = קנה מידה.",
      "body_by_level": {
        "la": {
          "body_en_md": "Prerequisite for eigenvalues.",
          "body_he_md": "תנאי לאי לערכים עצמיים."
        }
      }
    }
  ],
