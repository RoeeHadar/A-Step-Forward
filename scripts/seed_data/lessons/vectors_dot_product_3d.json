      {"id":"vde2","difficulty":"easy","body_en":"$|u|=5$, $|v|=8$, $\\theta=60°$. Dot?","body_he":"$|u|=5$, $|v|=8$, $\\theta=60°$. מכפלה?","solution_en":"$20$","solution_he":"$20$"},
      {"id":"vde3","difficulty":"easy","body_en":"$(1,0,0)\\times(0,1,0)$?","body_he":"$(1,0,0)\\times(0,1,0)$?","solution_en":"$(0,0,1)$","solution_he":"$(0,0,1)$"},
      {"id":"vde4","difficulty":"easy","body_en":"$(1,1,0)\\cdot(1,-1,0)$?","body_he":"$(1,1,0)\\cdot(1,-1,0)$?","solution_en":"$0$","solution_he":"$0$"},
      {"id":"vdm1","difficulty":"medium","body_en":"Angle between $(1,1,1)$ and $(1,0,0)$.","body_he":"זווית בין $(1,1,1)$ ו-$(1,0,0)$.","solution_en":"$\\cos\\theta=1/\\sqrt{3}$","solution_he":"$\\cos\\theta=1/\\sqrt{3}$"},
      {"id":"vdm2","difficulty":"medium","body_en":"Project $(3,4,0)$ onto $(1,0,0)$.","body_he":"הטל $(3,4,0)$ על $(1,0,0)$.","solution_en":"$(3,0,0)$","solution_he":"$(3,0,0)$"},
      {"id":"vdm3","difficulty":"medium","body_en":"Triangle area: origin, $(2,0,0)$, $(0,3,0)$.","body_he":"שטח: מקור, $(2,0,0)$, $(0,3,0)$.","solution_en":"$3$","solution_he":"$3$"},
      {"id":"vdm4","difficulty":"medium","body_en":"$|u\\times v|$ if $|u|=3$, $|v|=4$, angle $90°$.","body_he":"$|u\\times v|$ אם $|u|=3$, $|v|=4$, $90°$.","solution_en":"$12$","solution_he":"$12$"},
      {"id":"vdm5","difficulty":"medium","body_en":"Unit vector along $(3,4,0)$.","body_he":"וקטור יחידה בכיוון $(3,4,0)$.","solution_en":"$(3/5,4/5,0)$","solution_he":"$(3/5,4/5,0)$"},
      {"id":"vdh1","difficulty":"hard","body_en":"Parallelogram area: $\\vec{u}=(1,2,3)$, $\\vec{v}=(2,-1,1)$.","body_he":"שטח מקבילית: $\\vec{u}=(1,2,3)$, $\\vec{v}=(2,-1,1)$.","solution_en":"$\\sqrt{21}$","solution_he":"$\\sqrt{21}$"},
