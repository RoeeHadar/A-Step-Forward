      {"id":"vpm1","difficulty":"medium","body_en":"Angle between $(1,1)$ and $(1,0)$.","body_he":"זווית בין $(1,1)$ ו-$(1,0)$.","solution_en":"$45°$","solution_he":"$45°$"},
      {"id":"vpm2","difficulty":"medium","body_en":"Dot product $(2,3)\\cdot(4,-1)$.","body_he":"$(2,3)\\cdot(4,-1)$.","solution_en":"$5$","solution_he":"$5$"},
